# Babycare environment variables
# Copy this file to .env, then adjust values for your machine.

# App settings
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key

# Database
# Set USE_POSTGRES=False if you want to use the bundled SQLite file instead.
USE_POSTGRES=True
DB_NAME=babycare_db
DB_USER=postgres
DB_PASSWORD=replace-with-your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Optional integrations
FONNTE_API_KEY=
